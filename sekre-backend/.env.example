# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
SERVER_PORT=1000
# Options: development | staging | production
SERVER_ENV=development
SERVER_READ_TIMEOUT=15
SERVER_WRITE_TIMEOUT=15
SERVER_SHUTDOWN_TIMEOUT=30

# ─────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=2000
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=your-database
# Use "disable" for local, "require" for staging/production
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=3600

# ─────────────────────────────────────────────
# JWT Configuration
# ─────────────────────────────────────────────
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=10080

# ─────────────────────────────────────────────
# Logging Configuration
# ─────────────────────────────────────────────
# Options: debug | info | warn | error
# Recommended: debug (local), debug (staging), info (production)
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# CORS Configuration
# ─────────────────────────────────────────────
# NEVER use "*" with CORS_ALLOW_CREDENTIALS=true (security risk)
#
# Local development:
#   CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://192.168.x.x:3000
#
# Staging:
#   CORS_ALLOWED_ORIGINS=https://sekre-staging.example.com
#
# Production:
#   CORS_ALLOWED_ORIGINS=https://sekre.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Request-ID
CORS_EXPOSED_HEADERS=X-Request-ID
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# ─────────────────────────────────────────────
# Scheduler Configuration
# ─────────────────────────────────────────────
# How many days to keep expired refresh sessions before deleting them
CLEANUP_REFRESH_SESSION_RETENTION_DAYS=7
# How many days to keep audit log entries before deleting them
CLEANUP_AUDIT_LOG_RETENTION_DAYS=90

# ─────────────────────────────────────────────
# Self-Ping (Render free tier keep-alive)
# ─────────────────────────────────────────────
# Pings /health every 14 minutes to prevent Render free tier spin-down.
# Set to your Render service URL:
#   Staging:    https://sekre-backend-staging.onrender.com/health
#   Production: https://sekre-backend.onrender.com/health
# Leave empty to disable (recommended for local development)
SELF_PING_URL=

# ─────────────────────────────────────────────
# Local Development — URL Reference
# ─────────────────────────────────────────────
# Web browser (local):   http://localhost:1000
# iOS Simulator:         http://localhost:1000
# Android Emulator:      http://10.0.2.2:1000
# Physical device (LAN): http://<YOUR-LAN-IP>:1000
#   Find your LAN IP:
#     macOS/Linux: ifconfig | grep "inet " | grep -v 127.0.0.1
#     Windows:     ipconfig | findstr "IPv4"
#   Example: http://192.168.1.20:1000
