# Server Configuration
SERVER_PORT=1000
SERVER_ENV=development
SERVER_READ_TIMEOUT=15
SERVER_WRITE_TIMEOUT=15
SERVER_SHUTDOWN_TIMEOUT=30

# Database Configuration
DB_HOST=localhost
DB_PORT=2000
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=your-database
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=3600

# JWT Configuration
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_ACCESS_EXPIRY=15
JWT_REFRESH_EXPIRY=10080

# Logging Configuration
LOG_LEVEL=info

# CORS Configuration (comma-separated for list values)
# For production, replace with your actual frontend domains
# Example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com
# NEVER use "*" with CORS_ALLOW_CREDENTIALS=true (security risk)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-Request-ID
CORS_EXPOSED_HEADERS=X-Request-ID
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600
