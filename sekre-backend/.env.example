# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_NAME=sekre_db
DB_SSLMODE=disable

# JWT Configuration
# IMPORTANT: Generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-min-32-chars-generate-with-openssl-rand
JWT_ACCESS_TOKEN_TTL=24
JWT_REFRESH_TOKEN_TTL=168
