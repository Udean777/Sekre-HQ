      "name": "/auth/register",
      "item": [
        {
          "name": "Register a new organization",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Creates a new organization with the first user as Owner.\n\n**Registration Flow:**\n1. Submit organization and user details\n2. System creates organization with FREE plan\n3. First user is assigned OWNER role\n4. Returns access and refresh tokens\n\n**Password Requirements:**\n- Minimum 8 characters\n- At least one uppercase letter\n- At least one lowercase letter\n- At least one number\n- At least one special character\n",
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_name\": \"Acme Corporation\",\n  \"email\": \"admin@acme.com\",\n  \"password\": \"SecurePass123!\",\n  \"full_name\": \"John Doe\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch(e) {}",
                  "if (jsonData?.data?.tokens?.access_token) {",
                  "  pm.collectionVariables.set('access_token', jsonData.data.tokens.access_token);",
                  "}",
                  "if (jsonData?.data?.tokens?.refresh_token) {",
                  "  pm.collectionVariables.set('refresh_token', jsonData.data.tokens.refresh_token);",
                  "}",
                  "if (jsonData?.data?.access_token) {",
                  "  pm.collectionVariables.set('access_token', jsonData.data.access_token);",
                  "}",
                  "if (jsonData?.data?.refresh_token) {",
                  "  pm.collectionVariables.set('refresh_token', jsonData.data.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
