#!/bin/bash
#
# Pre-commit hook for sekre-backend
# Runs fast checks before allowing commits
#
# Setup:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-commit
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Running pre-commit checks..."
echo ""

# Change to backend directory
cd "$(git rev-parse --show-toplevel)/sekre-backend" || {
    echo "${RED}Error: sekre-backend directory not found${NC}"
    exit 1
}

# 1. Format check
echo "-> Running gofmt..."
UNFORMATTED=$(gofmt -l . 2>&1 | grep -v "^vendor/" || true)
if [ -n "$UNFORMATTED" ]; then
    echo "${RED}Error: The following files are not formatted:${NC}"
    echo "$UNFORMATTED"
    echo ""
    echo "${YELLOW}Run: gofmt -w .${NC}"
    exit 1
fi
echo "${GREEN}  OK${NC}"

# 2. Go vet
echo "-> Running go vet..."
if ! go vet ./... 2>&1; then
    echo "${RED}Error: go vet failed${NC}"
    exit 1
fi
echo "${GREEN}  OK${NC}"

# 3. Linter (fast mode)
echo "-> Running golangci-lint (fast mode)..."
if command -v golangci-lint &> /dev/null; then
    if ! golangci-lint run --fast --timeout=2m ./... 2>&1; then
        echo "${RED}Error: golangci-lint failed${NC}"
        exit 1
    fi
    echo "${GREEN}  OK${NC}"
else
    echo "${YELLOW}  (skipped: golangci-lint not installed)${NC}"
fi

# 4. Unit tests (short mode, no race to speed up)
echo "-> Running unit tests (short mode)..."
if ! go test -short -timeout=2m ./... 2>&1 | grep -E "(FAIL|ok|---)" | tail -20; then
    echo "${RED}Error: unit tests failed${NC}"
    exit 1
fi
echo "${GREEN}  OK${NC}"

# 5. Build check
echo "-> Checking build..."
if ! go build -o /dev/null ./... 2>&1; then
    echo "${RED}Error: build failed${NC}"
    exit 1
fi
echo "${GREEN}  OK${NC}"

echo ""
echo "${GREEN}All pre-commit checks passed!${NC}"
exit 0
