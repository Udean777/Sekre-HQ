# Environment Variables for Local Development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=sekre_user
DB_PASSWORD=sekre_password
DB_NAME=sekre_db
DB_SSLMODE=disable

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# Server Configuration
SERVER_PORT=8080
SERVER_ENV=development

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads

# Email Configuration (for future use)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@sekre.app

# AI Configuration (for future use)
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_MODEL=gpt-4

# Subscription Limits
FREE_MAX_DIVISIONS=7
FREE_MAX_MEMBERS_PER_DIVISION=15
LITE_MAX_DIVISIONS=15
LITE_MAX_MEMBERS_PER_DIVISION=30
