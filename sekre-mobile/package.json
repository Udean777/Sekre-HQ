{
  "name": "SekreMobile",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "prepare": "husky",
    "ios:fresh": "cd ios && pod install && cd .. && bunx react-native run-ios",
    "ios:clean": "rm -rf ~/Library/Developer/Xcode/DerivedData/SekreMobile-* && cd ios && pod deintegrate && pod install && cd .. && bunx react-native run-ios",
    "pods": "cd ios && pod install && cd ..",
    "sentry:upload-android": "sentry-cli releases files $(cat android/app/build.gradle | grep versionName | head -1 | awk -F'\"' '{print $2}') upload-sourcemaps --dist 1 --rewrite android/app/build/generated/sourcemaps/react/release/index.android.bundle.map",
    "sentry:upload-ios": "sentry-cli releases files $(cat ios/SekreMobile/Info.plist | grep -A1 CFBundleShortVersionString | tail -1 | sed 's/.*<string>\\(.*\\)<\\/string>.*/\\1/') upload-sourcemaps --dist 1 --rewrite ios/main.jsbundle.map",
    "analyze-bundle": "react-native-bundle-visualizer --platform android --out bundle-visualizer-output/android && react-native-bundle-visualizer --platform ios --out bundle-visualizer-output/ios",
    "check-bundle-budget": "node scripts/check-bundle-budget.js",
    "check-bundle-budget:update": "node scripts/check-bundle-budget.js --update-baseline"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@sentry/react-native": "^8.12.0",
    "@shopify/flash-list": "^2.3.1",
    "@tanstack/query-sync-storage-persister": "^5.100.11",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-persist-client": "^5.100.11",
    "@types/react-native-vector-icons": "^6.4.18",
    "axios": "^1.16.1",
    "date-fns": "^4.2.1",
    "i18next": "^26.2.0",
    "react": "19.2.3",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-bootsplash": "^7.3.1",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-keychain": "^10.0.0",
    "react-native-mmkv": "3",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "0.8",
    "react-redux": "^9.3.0",
    "redux-persist": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@sentry/cli": "3.4.3",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "9.17.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "react-native-bundle-visualizer": "3.1.3",
    "react-test-renderer": "19.2.3",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
